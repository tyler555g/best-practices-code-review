{
  "name": "@tyler.given/best-practices-code-review",
  "version": "0.1.0",
  "description": "Code review agent for best-practices — mechanical per-file-type checklist powered by @tyler.given/best-practices-content",
  "type": "module",
  "keywords": [
    "best-practices",
    "code-review",
    "ai-agent",
    "copilot",
    "claude",
    "github-actions"
  ],
  "homepage": "https://github.com/tyler555g/best-practices-code-review",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyler555g/best-practices-code-review.git"
  },
  "license": "MIT",
  "author": "tyler555g",
  "bin": {
    "best-practices-code-review": "bin/setup.js"
  },
  "main": "bin/setup.js",
  "files": [
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".github/instructions/",
    "content/",
    "bin/"
  ],
  "scripts": {
    "postinstall": "node bin/setup.js",
    "setup": "node bin/setup.js",
    "test": "node --test tests/*.test.js",
    "audit:deps": "npm audit --audit-level=moderate"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@tyler.given/best-practices-content": "*"
  },
  "peerDependenciesMeta": {
    "@tyler.given/best-practices-content": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0"
  }
}
